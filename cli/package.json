{
  "name": "aiep-skills",
  "version": "0.1.0",
  "private": true,
  "type": "commonjs",
  "description": "CLI del framework AIEP: instala/actualiza skills y tooling en un repo de curso (copiar + lock).",
  "bin": {
    "aiep-skills": "./dist/index.js"
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsx src/index.ts",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:text": "cspell lint --config cspell.json \"src/**/*.ts\" \"tests/**/*.ts\"",
    "test:all": "npm run typecheck && npm run build && npm run test && npm run test:text"
  },
  "devDependencies": {
    "@cspell/dict-es-es": "^2.3.0",
    "@types/node": "^24.5.2",
    "cspell": "^8.19.4",
    "tsup": "^8.5.0",
    "tsx": "^4.20.5",
    "typescript": "^5.9.2",
    "vitest": "^3.2.4"
  }
}
